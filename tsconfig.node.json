{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["electron", "vite.config.ts", "branding.json"]
}
